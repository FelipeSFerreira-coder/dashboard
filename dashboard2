<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Nexenergia — Dashboard de Obras</title>
  <script src="https://unpkg.com/react@18/umd/react.production.min.js" crossorigin></script>
  <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js" crossorigin></script>
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50">
  <div id="root"></div>

  <script type="text/babel">
    const { useState, useMemo, useRef, useEffect } = React;

    const GREEN      = "#16a34a";
    const GREEN_LIGHT= "#bbf7d0";
    const AMBER      = "#f59e0b";
    const meses      = ["Jan","Fev","Mar","Abr","Mai","Jun","Jul","Ago","Set","Out","Nov","Dez"];

    const ETAPAS = [
      "Solicitação de Documentação ao Cliente",
      "Criação do Projeto",
      "Entrada do Projeto na Coelba",
      "Análise de Projeto Coelba",
      "Aprovação do Projeto",
      "Compra de Material",
      "Obra em Andamento",
      "Obra Concluída",
      "Solicitação de Interligação",
      "Interligação Realizada",
    ];

    const STATUS_ETAPA = ["Pendente","Em andamento","Concluído"];
    const etapaVazia  = () => ETAPAS.map(() => ({ status: "Pendente", obs: "" }));

    const obraInit = [
      { id: 1, obra: "Trecho A — Centro",     cliente: "Prefeitura Municipal", mes: "Jan", prevInicio: "2025-01-10", prevFim: "2025-03-10", prevPostes: 40, realPostes: 38, prevCabo: 1200, realCabo: 1100, etapas: ETAPAS.map((_, i) => ({ status: i < 7 ? "Concluído" : i === 7 ? "Em andamento" : "Pendente", obs: "" })) },
      { id: 2, obra: "Trecho B — Bairro Sul", cliente: "Construtora Beta",      mes: "Fev", prevInicio: "2025-02-01", prevFim: "2025-05-01", prevPostes: 60, realPostes: 45, prevCabo: 1800, realCabo: 1600, etapas: ETAPAS.map((_, i) => ({ status: i < 3 ? "Concluído" : i === 3 ? "Em andamento" : "Pendente", obs: "" })) },
      { id: 3, obra: "Trecho C — Zona Norte", cliente: "Copel Distribuição",    mes: "Mar", prevInicio: "2025-03-15", prevFim: "2025-06-15", prevPostes: 30, realPostes: 30, prevCabo:  900, realCabo:  920, etapas: ETAPAS.map((_, i) => ({ status: i < 8 ? "Concluído" : i === 8 ? "Em andamento" : "Pendente", obs: "" })) },
    ];

    const emptyForm = { obra: "", cliente: "", mes: "Jan", prevInicio: "", prevFim: "", prevPostes: "", realPostes: "", prevCabo: "", realCabo: "", etapas: etapaVazia() };

    const CARGOS = ["Eletricista", "Ajudante"];
    const funcInit = [
      { id: 1, nome: "João Silva",     cargo: "Eletricista", valorDiaria: 250 },
      { id: 2, nome: "Pedro Oliveira", cargo: "Ajudante",    valorDiaria: 180 },
    ];
    const diariasInit = [
      { id: 1, funcionarioId: 1, data: "2026-04-01", obra: "Trecho A — Centro",     obs: "" },
      { id: 2, funcionarioId: 1, data: "2026-04-02", obra: "Trecho A — Centro",     obs: "" },
      { id: 3, funcionarioId: 2, data: "2026-04-01", obra: "Trecho A — Centro",     obs: "" },
      { id: 4, funcionarioId: 2, data: "2026-04-02", obra: "Trecho B — Bairro Sul", obs: "" },
      { id: 5, funcionarioId: 2, data: "2026-04-03", obra: "Trecho B — Bairro Sul", obs: "" },
    ];
    const emptyFormFunc   = { nome: "", cargo: "Eletricista", valorDiaria: "" };
    const emptyFormDiaria = { funcionarioId: "", data: "", obra: "", obs: "" };

    // ── utils ─────────────────────────────────────────────────────────────────
    const pct = (r, p) => p > 0 ? Math.min(100, Math.round((r / p) * 100)) : 0;

    const etapaAtual = (etapas) => {
      let idx = -1;
      etapas.forEach((e, i) => { if (e.status !== "Pendente") idx = i; });
      return idx;
    };

    const corStatus = { "Concluído": GREEN, "Em andamento": "#ca8a04", "Pendente": "#d1d5db" };
    const bgStatus  = { "Concluído": "bg-green-100 text-green-700", "Em andamento": "bg-yellow-100 text-yellow-700", "Pendente": "bg-gray-100 text-gray-500" };

    // ── componentes base ──────────────────────────────────────────────────────
    const ProgressBar = ({ value }) => {
      const c = value >= 100 ? GREEN : value >= 60 ? "#ca8a04" : "#dc2626";
      return (
        <div className="w-full bg-gray-100 rounded-full h-2">
          <div style={{ width: `${Math.min(value,100)}%`, backgroundColor: c }} className="h-2 rounded-full transition-all" />
        </div>
      );
    };

    const Badge = ({ value }) => (
      <span className={`px-2 py-0.5 rounded-full text-xs font-bold ${value >= 100 ? "bg-green-100 text-green-700" : value >= 60 ? "bg-yellow-100 text-yellow-700" : "bg-red-100 text-red-600"}`}>{value}%</span>
    );

    const StatusBadge = ({ s }) => <span className={`px-2 py-0.5 rounded-full text-xs font-medium ${bgStatus[s] || ""}`}>{s}</span>;

    const Inp = ({ label, value, onChange, type = "text" }) => (
      <div className="flex flex-col gap-1">
        <label className="text-xs text-gray-500 font-medium">{label}</label>
        <input type={type} value={value} onChange={e => onChange(e.target.value)}
          className="border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-400" />
      </div>
    );

    const Sel = ({ label, value, onChange, options }) => (
      <div className="flex flex-col gap-1">
        <label className="text-xs text-gray-500 font-medium">{label}</label>
        <select value={value} onChange={e => onChange(e.target.value)}
          className="border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-400">
          {options.map(o => <option key={o}>{o}</option>)}
        </select>
      </div>
    );

    // ── Chart.js wrappers ─────────────────────────────────────────────────────
    const BarChartComp = ({ data, ds1Key, ds2Key, ds1Label, ds2Label }) => {
      const ref = useRef(null);
      const inst = useRef(null);
      useEffect(() => {
        if (inst.current) inst.current.destroy();
        inst.current = new Chart(ref.current, {
          type: "bar",
          data: {
            labels: data.map(d => d.m),
            datasets: [
              { label: ds1Label, data: data.map(d => d[ds1Key]), backgroundColor: GREEN_LIGHT, borderRadius: 4 },
              { label: ds2Label, data: data.map(d => d[ds2Key]), backgroundColor: GREEN,       borderRadius: 4 },
            ]
          },
          options: { responsive: true, plugins: { legend: { position: "bottom" } }, scales: { y: { beginAtZero: true } } }
        });
        return () => inst.current && inst.current.destroy();
      }, [JSON.stringify(data)]);
      return <canvas ref={ref} />;
    };

    const LineChartComp = ({ data }) => {
      const ref = useRef(null);
      const inst = useRef(null);
      useEffect(() => {
        if (inst.current) inst.current.destroy();
        inst.current = new Chart(ref.current, {
          type: "line",
          data: {
            labels: data.map(d => d.m),
            datasets: [
              { label: "% Postes", data: data.map(d => pct(d.realPostes, d.prevPostes)), borderColor: GREEN, backgroundColor: GREEN + "33", tension: 0.3, fill: false, pointBackgroundColor: GREEN },
              { label: "% Cabo",   data: data.map(d => pct(d.realCabo,   d.prevCabo)),   borderColor: AMBER, backgroundColor: AMBER + "33", tension: 0.3, fill: false, pointBackgroundColor: AMBER },
            ]
          },
          options: { responsive: true, plugins: { legend: { position: "bottom" } }, scales: { y: { beginAtZero: true, max: 100, ticks: { callback: v => v + "%" } } } }
        });
        return () => inst.current && inst.current.destroy();
      }, [JSON.stringify(data)]);
      return <canvas ref={ref} />;
    };

    // ── Pipeline card ─────────────────────────────────────────────────────────
    const PipelineCard = ({ obra, onUpdate }) => {
      const [open, setOpen] = useState(false);
      const etapaIdx  = etapaAtual(obra.etapas);
      const progresso = Math.round((obra.etapas.filter(e => e.status === "Concluído").length / ETAPAS.length) * 100);

      const updEtapa = (i, field, val) => {
        const etapas = obra.etapas.map((e, idx) => idx === i ? { ...e, [field]: val } : e);
        onUpdate({ ...obra, etapas });
      };

      return (
        <div className="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
          <div className="px-5 py-4 flex items-center justify-between cursor-pointer hover:bg-gray-50 transition-colors" onClick={() => setOpen(o => !o)}>
            <div className="flex-1 min-w-0">
              <div className="flex items-center gap-3 flex-wrap">
                <span className="font-semibold text-gray-800">{obra.obra}</span>
                <span className="text-xs text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full">{obra.mes}</span>
                {etapaIdx >= 0 && <StatusBadge s={obra.etapas[etapaIdx].status} />}
              </div>
              <p className="text-xs text-gray-400 mt-0.5">👤 {obra.cliente}</p>
              <div className="flex items-center gap-3 mt-2">
                <div className="flex-1 max-w-xs"><ProgressBar value={progresso} /></div>
                <span className="text-xs font-semibold" style={{ color: GREEN }}>{progresso}%</span>
                <span className="text-xs text-gray-400">{etapaIdx >= 0 ? ETAPAS[etapaIdx] : "Não iniciado"}</span>
              </div>
            </div>
            <span className="ml-4 text-gray-400 text-lg">{open ? "▲" : "▼"}</span>
          </div>

          {open && (
            <div className="border-t border-gray-100 px-5 py-4 space-y-3">
              {ETAPAS.map((nome, i) => (
                <div key={i} className={`rounded-xl p-4 border ${obra.etapas[i].status === "Concluído" ? "border-green-100 bg-green-50" : obra.etapas[i].status === "Em andamento" ? "border-yellow-100 bg-yellow-50" : "border-gray-100 bg-gray-50"}`}>
                  <div className="flex items-center gap-3 flex-wrap mb-2">
                    <div className="w-6 h-6 rounded-full flex items-center justify-center text-white text-xs font-bold flex-shrink-0"
                      style={{ backgroundColor: corStatus[obra.etapas[i].status] }}>
                      {obra.etapas[i].status === "Concluído" ? "✓" : i + 1}
                    </div>
                    <span className="text-sm font-medium text-gray-700 flex-1">{nome}</span>
                    <select value={obra.etapas[i].status} onChange={e => updEtapa(i, "status", e.target.value)}
                      className="text-xs border border-gray-200 rounded-lg px-2 py-1 bg-white focus:outline-none focus:ring-1 focus:ring-green-400">
                      {STATUS_ETAPA.map(s => <option key={s}>{s}</option>)}
                    </select>
                  </div>
                  <textarea value={obra.etapas[i].obs} onChange={e => updEtapa(i, "obs", e.target.value)}
                    placeholder="Observação / atualização desta etapa..." rows={2}
                    className="w-full text-xs border border-gray-200 rounded-lg px-3 py-2 resize-none bg-white focus:outline-none focus:ring-1 focus:ring-green-400" />
                </div>
              ))}
            </div>
          )}
        </div>
      );
    };

    // ── Dashboard principal ───────────────────────────────────────────────────
    function Dashboard() {
      const [tab, setTab]               = useState("overview");
      const [obras, setObras]           = useState(obraInit);
      const [form, setForm]             = useState(emptyForm);
      const [editId, setEditId]         = useState(null);
      const [companyName, setCompany]   = useState("Nexenergia");
      const [editingName, setEditingName] = useState(false);
      const [funcionarios, setFuncionarios] = useState(funcInit);
      const [diarias, setDiarias]           = useState(diariasInit);
      const [formFunc, setFormFunc]         = useState(emptyFormFunc);
      const [formDiaria, setFormDiaria]     = useState(emptyFormDiaria);
      const [editFuncId, setEditFuncId]     = useState(null);
      const [editDiariaId, setEditDiariaId] = useState(null);
      const [subTab, setSubTab]             = useState("resumo");
      const [filtroMes, setFiltroMes]       = useState("Todos");

      const setF  = (k, v) => setForm(p => ({ ...p, [k]: v }));
      const setFF = (k, v) => setFormFunc(p => ({ ...p, [k]: v }));
      const setFD = (k, v) => setFormDiaria(p => ({ ...p, [k]: v }));
      const updateObra = updated => setObras(p => p.map(o => o.id === updated.id ? updated : o));

      const totalPrevPostes = obras.reduce((a, o) => a + (+o.prevPostes || 0), 0);
      const totalRealPostes = obras.reduce((a, o) => a + (+o.realPostes || 0), 0);
      const totalPrevCabo   = obras.reduce((a, o) => a + (+o.prevCabo   || 0), 0);
      const totalRealCabo   = obras.reduce((a, o) => a + (+o.realCabo   || 0), 0);
      const pctPostes = pct(totalRealPostes, totalPrevPostes);
      const pctCabo   = pct(totalRealCabo,   totalPrevCabo);

      const chartData = useMemo(() => {
        const map = {};
        meses.forEach(m => map[m] = { m, prevPostes: 0, realPostes: 0, prevCabo: 0, realCabo: 0 });
        obras.forEach(o => {
          if (map[o.mes]) {
            map[o.mes].prevPostes += +o.prevPostes || 0;
            map[o.mes].realPostes += +o.realPostes || 0;
            map[o.mes].prevCabo   += +o.prevCabo   || 0;
            map[o.mes].realCabo   += +o.realCabo   || 0;
          }
        });
        return Object.values(map);
      }, [obras]);

      const diariasFiltradas = useMemo(() => {
        if (filtroMes === "Todos") return diarias;
        return diarias.filter(d => meses[new Date(d.data + "T00:00:00").getMonth()] === filtroMes);
      }, [diarias, filtroMes]);

      const resumo = useMemo(() => funcionarios.map(f => {
        const dias = diariasFiltradas.filter(d => d.funcionarioId === f.id);
        return { ...f, totalDias: dias.length, totalPagar: dias.length * f.valorDiaria };
      }), [funcionarios, diariasFiltradas]);

      const saveRow = () => {
        if (!form.obra) return;
        if (editId !== null) {
          setObras(p => p.map(o => o.id === editId ? { ...form, id: editId } : o));
          setEditId(null);
        } else {
          setObras(p => [...p, { ...form, id: Date.now() }]);
        }
        setForm(emptyForm);
      };

      const startEdit  = o => { setForm({ ...o }); setEditId(o.id); setTab("lancamentos"); };
      const cancelEdit = () => { setForm(emptyForm); setEditId(null); };

      const saveFunc = () => {
        if (!formFunc.nome || !formFunc.valorDiaria) return;
        if (editFuncId !== null) {
          setFuncionarios(p => p.map(f => f.id === editFuncId ? { ...formFunc, id: editFuncId, valorDiaria: +formFunc.valorDiaria } : f));
          setEditFuncId(null);
        } else {
          setFuncionarios(p => [...p, { ...formFunc, id: Date.now(), valorDiaria: +formFunc.valorDiaria }]);
        }
        setFormFunc(emptyFormFunc);
      };

      const saveDiaria = () => {
        if (!formDiaria.funcionarioId || !formDiaria.data) return;
        if (editDiariaId !== null) {
          setDiarias(p => p.map(d => d.id === editDiariaId ? { ...formDiaria, id: editDiariaId, funcionarioId: +formDiaria.funcionarioId } : d));
          setEditDiariaId(null);
        } else {
          setDiarias(p => [...p, { ...formDiaria, id: Date.now(), funcionarioId: +formDiaria.funcionarioId }]);
        }
        setFormDiaria(emptyFormDiaria);
      };

      const tabs = [
        { key: "overview",    label: "Visão Geral" },
        { key: "projetos",    label: "Gestão de Projetos" },
        { key: "lancamentos", label: "Lançamentos" },
        { key: "graficos",    label: "Gráficos" },
        { key: "diarias",     label: "Diárias" },
      ];

      return (
        <div className="min-h-screen bg-gray-50">
          {/* Header */}
          <header style={{ backgroundColor: GREEN }} className="text-white px-6 py-4 flex items-center justify-between shadow">
            <div className="flex items-center gap-3">
              <div className="w-8 h-8 rounded-full bg-white flex items-center justify-center">
                <span style={{ color: GREEN }} className="font-bold text-sm">{companyName[0]}</span>
              </div>
              {editingName
                ? <input autoFocus value={companyName} onChange={e => setCompany(e.target.value)}
                    onBlur={() => setEditingName(false)} onKeyDown={e => e.key === "Enter" && setEditingName(false)}
                    className="bg-white/20 text-white rounded px-2 py-0.5 text-lg font-semibold outline-none border border-white/40" />
                : <span className="text-lg font-semibold cursor-pointer hover:opacity-80" onClick={() => setEditingName(true)}>{companyName}</span>
              }
            </div>
            <span className="text-sm opacity-80">Obras de Rede Elétrica</span>
          </header>

          {/* Tabs */}
          <nav className="bg-white border-b border-gray-200 px-6 flex gap-1 overflow-x-auto">
            {tabs.map(t => (
              <button key={t.key} onClick={() => setTab(t.key)}
                className={`px-4 py-3 text-sm font-medium border-b-2 whitespace-nowrap transition-colors ${tab === t.key ? "border-green-600 text-green-700" : "border-transparent text-gray-500 hover:text-gray-700"}`}>
                {t.label}
              </button>
            ))}
          </nav>

          <main className="p-6 max-w-6xl mx-auto" style={{ display: "flex", flexDirection: "column", gap: "1.5rem" }}>

            {/* KPIs */}
            {(tab === "overview" || tab === "graficos") && (
              <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
                {[
                  { label: "Postes Previstos",   value: totalPrevPostes.toLocaleString(), sub: "total planejado",       bar: null },
                  { label: "Postes Implantados", value: totalRealPostes.toLocaleString(), sub: `avanço: ${pctPostes}%`, bar: pctPostes },
                  { label: "Cabo Previsto (m)",  value: totalPrevCabo.toLocaleString(),   sub: "total planejado",       bar: null },
                  { label: "Cabo Lançado (m)",   value: totalRealCabo.toLocaleString(),   sub: `avanço: ${pctCabo}%`,   bar: pctCabo },
                ].map(k => (
                  <div key={k.label} className="bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
                    <p className="text-xs text-gray-400 font-medium mb-1">{k.label}</p>
                    <p style={{ color: GREEN }} className="text-2xl font-bold">{k.value}</p>
                    {k.bar !== null && <div className="mt-2"><ProgressBar value={k.bar} /></div>}
                    <p className="text-xs text-gray-400 mt-1">{k.sub}</p>
                  </div>
                ))}
              </div>
            )}

            {/* Visão Geral */}
            {tab === "overview" && (
              <div className="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
                <div className="px-5 py-4 border-b border-gray-100">
                  <h3 className="font-semibold text-gray-700">Andamento por Trecho / Obra</h3>
                </div>
                <div className="overflow-x-auto">
                  <table className="w-full text-sm">
                    <thead>
                      <tr className="text-xs text-gray-400 bg-gray-50 uppercase tracking-wide">
                        <th className="text-left px-4 py-3">Obra</th>
                        <th className="text-left px-4 py-3">Cliente</th>
                        <th className="text-left px-4 py-3">Mês</th>
                        <th className="text-center px-3 py-3">% Postes</th>
                        <th className="text-center px-3 py-3">% Cabo</th>
                        <th className="text-center px-3 py-3">Etapa Atual</th>
                      </tr>
                    </thead>
                    <tbody>
                      {obras.map(o => {
                        const idx = etapaAtual(o.etapas);
                        return (
                          <tr key={o.id} className="border-t border-gray-50 hover:bg-gray-50">
                            <td className="px-4 py-3 font-medium text-gray-700">{o.obra}</td>
                            <td className="px-4 py-3 text-gray-500">{o.cliente}</td>
                            <td className="px-4 py-3 text-gray-400">{o.mes}</td>
                            <td className="px-3 py-3 text-center"><Badge value={pct(o.realPostes, o.prevPostes)} /></td>
                            <td className="px-3 py-3 text-center"><Badge value={pct(o.realCabo,   o.prevCabo)}   /></td>
                            <td className="px-3 py-3 text-center text-xs text-gray-500">{idx >= 0 ? ETAPAS[idx] : "Não iniciado"}</td>
                          </tr>
                        );
                      })}
                    </tbody>
                  </table>
                </div>
              </div>
            )}

            {/* Gestão de Projetos */}
            {tab === "projetos" && (
              <div style={{ display: "flex", flexDirection: "column", gap: "1rem" }}>
                <div className="flex items-center justify-between">
                  <h2 className="font-semibold text-gray-700">Gestão de Projetos — Pipeline de Etapas</h2>
                  <span className="text-xs text-gray-400">{obras.length} projetos</span>
                </div>
                <div className="flex gap-4 text-xs text-gray-500 bg-white rounded-xl px-4 py-3 border border-gray-100 shadow-sm flex-wrap">
                  <span className="font-semibold text-gray-600">Legenda:</span>
                  {Object.entries(corStatus).map(([s, c]) => (
                    <span key={s} style={{ display: "flex", alignItems: "center", gap: "6px" }}>
                      <span style={{ width: 12, height: 12, borderRadius: "50%", backgroundColor: c, display: "inline-block" }} />
                      {s}
                    </span>
                  ))}
                </div>
                {obras.map(o => <PipelineCard key={o.id} obra={o} onUpdate={updateObra} />)}
              </div>
            )}

            {/* Lançamentos */}
            {tab === "lancamentos" && (
              <div className="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
                <div className="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
                  <h3 className="font-semibold text-gray-700">Lançamentos de Implantação</h3>
                  <span className="text-xs text-gray-400">{obras.length} registros</span>
                </div>
                <div className="overflow-x-auto">
                  <table className="w-full text-sm">
                    <thead>
                      <tr className="text-xs text-gray-400 bg-gray-50 uppercase tracking-wide">
                        <th className="text-left px-4 py-3">Obra / Trecho</th>
                        <th className="text-left px-4 py-3">Cliente</th>
                        <th className="text-left px-4 py-3">Mês</th>
                        <th className="text-center px-3 py-3">Início Prev.</th>
                        <th className="text-center px-3 py-3">Fim Prev.</th>
                        <th className="text-center px-3 py-3">Prev. Postes</th>
                        <th className="text-center px-3 py-3">Real. Postes</th>
                        <th className="text-center px-3 py-3">% Postes</th>
                        <th className="text-center px-3 py-3">Prev. Cabo (m)</th>
                        <th className="text-center px-3 py-3">Real. Cabo (m)</th>
                        <th className="text-center px-3 py-3">% Cabo</th>
                        <th className="px-4 py-3"></th>
                      </tr>
                    </thead>
                    <tbody>
                      {obras.map(o => {
                        const pp = pct(+o.realPostes, +o.prevPostes);
                        const pc = pct(+o.realCabo,   +o.prevCabo);
                        return (
                          <tr key={o.id} className="border-t border-gray-50 hover:bg-gray-50">
                            <td className="px-4 py-3 font-medium text-gray-700 whitespace-nowrap">{o.obra}</td>
                            <td className="px-4 py-3 text-gray-500 whitespace-nowrap">{o.cliente}</td>
                            <td className="px-4 py-3 text-gray-400">{o.mes}</td>
                            <td className="px-3 py-3 text-center text-gray-500 text-xs">{o.prevInicio || "—"}</td>
                            <td className="px-3 py-3 text-center text-gray-500 text-xs">{o.prevFim    || "—"}</td>
                            <td className="px-3 py-3 text-center text-gray-600">{(+o.prevPostes).toLocaleString()}</td>
                            <td className="px-3 py-3 text-center text-gray-600">{(+o.realPostes).toLocaleString()}</td>
                            <td className="px-3 py-3 text-center">
                              <div style={{ display:"flex", flexDirection:"column", alignItems:"center", gap:"4px" }}>
                                <Badge value={pp} /><ProgressBar value={pp} />
                              </div>
                            </td>
                            <td className="px-3 py-3 text-center text-gray-600">{(+o.prevCabo).toLocaleString()}</td>
                            <td className="px-3 py-3 text-center text-gray-600">{(+o.realCabo).toLocaleString()}</td>
                            <td className="px-3 py-3 text-center">
                              <div style={{ display:"flex", flexDirection:"column", alignItems:"center", gap:"4px" }}>
                                <Badge value={pc} /><ProgressBar value={pc} />
                              </div>
                            </td>
                            <td className="px-4 py-3">
                              <div style={{ display:"flex", gap:"8px", justifyContent:"flex-end" }}>
                                <button onClick={() => startEdit(o)} style={{ fontSize:"12px", color:"#60a5fa", cursor:"pointer", background:"none", border:"none" }}>✎</button>
                                <button onClick={() => setObras(p => p.filter(x => x.id !== o.id))} style={{ fontSize:"12px", color:"#f87171", cursor:"pointer", background:"none", border:"none" }}>✕</button>
                              </div>
                            </td>
                          </tr>
                        );
                      })}
                    </tbody>
                    <tfoot>
                      <tr style={{ borderTop: "2px solid #dcfce7", backgroundColor: "#f0fdf4" }} className="font-semibold text-sm">
                        <td className="px-4 py-3 text-green-700" colSpan={5}>TOTAL GERAL</td>
                        <td className="px-3 py-3 text-center text-green-700">{totalPrevPostes.toLocaleString()}</td>
                        <td className="px-3 py-3 text-center text-green-700">{totalRealPostes.toLocaleString()}</td>
                        <td className="px-3 py-3 text-center"><Badge value={pctPostes} /></td>
                        <td className="px-3 py-3 text-center text-green-700">{totalPrevCabo.toLocaleString()}</td>
                        <td className="px-3 py-3 text-center text-green-700">{totalRealCabo.toLocaleString()}</td>
                        <td className="px-3 py-3 text-center"><Badge value={pctCabo} /></td>
                        <td></td>
                      </tr>
                    </tfoot>
                  </table>
                </div>

                {/* Formulário */}
                <div className="px-5 py-5 border-t border-gray-100 bg-gray-50">
                  <p className="text-xs font-semibold text-gray-500 mb-3">{editId !== null ? "✎ Editando registro" : "Novo Lançamento"}</p>
                  <div className="grid grid-cols-2 md:grid-cols-4 gap-3">
                    <div className="col-span-2"><Inp label="Obra / Trecho"   value={form.obra}       onChange={v => setF("obra", v)} /></div>
                    <div className="col-span-2"><Inp label="Cliente"         value={form.cliente}    onChange={v => setF("cliente", v)} /></div>
                    <Sel label="Mês"              value={form.mes}           onChange={v => setF("mes", v)}        options={meses} />
                    <Inp label="Prev. Início"     value={form.prevInicio}    onChange={v => setF("prevInicio", v)} type="date" />
                    <Inp label="Prev. Fim"        value={form.prevFim}       onChange={v => setF("prevFim", v)}    type="date" />
                    <div />
                    <Inp label="Prev. Postes"     value={form.prevPostes}    onChange={v => setF("prevPostes", v)} type="number" />
                    <Inp label="Real. Postes"     value={form.realPostes}    onChange={v => setF("realPostes", v)} type="number" />
                    <Inp label="Prev. Cabo (m)"   value={form.prevCabo}      onChange={v => setF("prevCabo", v)}   type="number" />
                    <Inp label="Real. Cabo (m)"   value={form.realCabo}      onChange={v => setF("realCabo", v)}   type="number" />
                  </div>
                  <div style={{ display:"flex", gap:"8px", marginTop:"16px" }}>
                    <button onClick={saveRow} style={{ backgroundColor: GREEN, color:"white", fontSize:"14px", padding:"8px 24px", borderRadius:"8px", border:"none", cursor:"pointer", fontWeight:500 }}>
                      {editId !== null ? "Salvar Edição" : "+ Lançar"}
                    </button>
                    {editId !== null && (
                      <button onClick={cancelEdit} style={{ fontSize:"14px", padding:"8px 24px", borderRadius:"8px", border:"1px solid #d1d5db", color:"#6b7280", background:"white", cursor:"pointer" }}>Cancelar</button>
                    )}
                  </div>
                </div>
              </div>
            )}

            {/* Gráficos */}
            {tab === "graficos" && (
              <div className="grid md:grid-cols-2 gap-4">
                <div className="bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
                  <h3 className="text-sm font-semibold text-gray-600 mb-4">Postes — Previsto vs Realizado</h3>
                  <BarChartComp data={chartData} ds1Key="prevPostes" ds2Key="realPostes" ds1Label="Previsto" ds2Label="Realizado" />
                </div>
                <div className="bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
                  <h3 className="text-sm font-semibold text-gray-600 mb-4">Cabo (m) — Previsto vs Realizado</h3>
                  <BarChartComp data={chartData} ds1Key="prevCabo" ds2Key="realCabo" ds1Label="Previsto" ds2Label="Realizado" />
                </div>
                <div className="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 md:col-span-2">
                  <h3 className="text-sm font-semibold text-gray-600 mb-4">Curva de Avanço (%) — Postes e Cabo por Mês</h3>
                  <LineChartComp data={chartData} />
                </div>
              </div>
            )}

            {/* ── Diárias ─────────────────────────────────────────────────────── */}
            {tab === "diarias" && (
              <div style={{ display:"flex", flexDirection:"column", gap:"1rem" }}>
                <div className="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">

                  {/* Sub-navegação */}
                  <div className="flex border-b border-gray-100 overflow-x-auto">
                    {[
                      { key: "resumo",       label: "Resumo de Pagamentos" },
                      { key: "lancamentos",  label: "Lançamentos" },
                      { key: "funcionarios", label: "Funcionários" },
                    ].map(st => (
                      <button key={st.key} onClick={() => setSubTab(st.key)}
                        className={`px-5 py-3 text-sm font-medium border-b-2 whitespace-nowrap transition-colors ${subTab === st.key ? "border-green-600 text-green-700" : "border-transparent text-gray-500 hover:text-gray-700"}`}>
                        {st.label}
                      </button>
                    ))}
                  </div>

                  {/* ── Resumo ── */}
                  {subTab === "resumo" && (
                    <div>
                      <div className="px-5 py-4 border-b border-gray-100 flex items-center gap-3 flex-wrap">
                        <h3 className="font-semibold text-gray-700 flex-1">Resumo de Diárias e Pagamentos</h3>
                        <div style={{ display:"flex", alignItems:"center", gap:"8px" }}>
                          <span className="text-xs text-gray-500">Filtrar mês:</span>
                          <select value={filtroMes} onChange={e => setFiltroMes(e.target.value)}
                            className="border border-gray-200 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-green-400">
                            <option>Todos</option>
                            {meses.map(m => <option key={m}>{m}</option>)}
                          </select>
                        </div>
                      </div>
                      <div className="grid grid-cols-2 md:grid-cols-3 gap-4 p-5">
                        {[
                          { label: "Total de Diárias",    value: diariasFiltradas.length,                                                                                sub: filtroMes === "Todos" ? "todos os períodos" : filtroMes },
                          { label: "Total a Pagar",        value: resumo.reduce((a,r) => a+r.totalPagar, 0).toLocaleString("pt-BR",{style:"currency",currency:"BRL"}), sub: filtroMes === "Todos" ? "todos os períodos" : filtroMes },
                          { label: "Funcionários Ativos",  value: resumo.filter(r => r.totalDias > 0).length,                                                           sub: "com diárias no período" },
                        ].map(k => (
                          <div key={k.label} className="bg-gray-50 rounded-xl p-4 border border-gray-100">
                            <p className="text-xs text-gray-400 font-medium mb-1">{k.label}</p>
                            <p className="text-2xl font-bold" style={{ color: GREEN }}>{k.value}</p>
                            <p className="text-xs text-gray-400 mt-1">{k.sub}</p>
                          </div>
                        ))}
                      </div>
                      <div className="overflow-x-auto">
                        <table className="w-full text-sm">
                          <thead>
                            <tr className="text-xs text-gray-400 bg-gray-50 uppercase tracking-wide">
                              <th className="text-left px-4 py-3">Funcionário</th>
                              <th className="text-left px-4 py-3">Cargo</th>
                              <th className="text-center px-4 py-3">Diárias</th>
                              <th className="text-center px-4 py-3">Valor Diária</th>
                              <th className="text-center px-4 py-3">Total a Pagar</th>
                            </tr>
                          </thead>
                          <tbody>
                            {resumo.map(r => (
                              <tr key={r.id} className="border-t border-gray-50 hover:bg-gray-50">
                                <td className="px-4 py-3 font-medium text-gray-700">{r.nome}</td>
                                <td className="px-4 py-3">
                                  <span className={`px-2 py-0.5 rounded-full text-xs font-medium ${r.cargo === "Eletricista" ? "bg-blue-100 text-blue-700" : "bg-orange-100 text-orange-700"}`}>{r.cargo}</span>
                                </td>
                                <td className="px-4 py-3 text-center font-semibold text-gray-700">{r.totalDias}</td>
                                <td className="px-4 py-3 text-center text-gray-600">{r.valorDiaria.toLocaleString("pt-BR",{style:"currency",currency:"BRL"})}</td>
                                <td className="px-4 py-3 text-center font-bold" style={{ color: GREEN }}>{r.totalPagar.toLocaleString("pt-BR",{style:"currency",currency:"BRL"})}</td>
                              </tr>
                            ))}
                          </tbody>
                          <tfoot>
                            <tr style={{ borderTop:"2px solid #dcfce7", backgroundColor:"#f0fdf4" }} className="font-semibold text-sm">
                              <td className="px-4 py-3 text-green-700" colSpan={2}>TOTAL GERAL</td>
                              <td className="px-4 py-3 text-center text-green-700">{diariasFiltradas.length}</td>
                              <td></td>
                              <td className="px-4 py-3 text-center font-bold text-green-700">{resumo.reduce((a,r) => a+r.totalPagar, 0).toLocaleString("pt-BR",{style:"currency",currency:"BRL"})}</td>
                            </tr>
                          </tfoot>
                        </table>
                      </div>
                    </div>
                  )}

                  {/* ── Lançamentos de diárias ── */}
                  {subTab === "lancamentos" && (
                    <div>
                      <div className="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
                        <h3 className="font-semibold text-gray-700">Registro de Diárias</h3>
                        <span className="text-xs text-gray-400">{diarias.length} registros</span>
                      </div>
                      <div className="overflow-x-auto">
                        <table className="w-full text-sm">
                          <thead>
                            <tr className="text-xs text-gray-400 bg-gray-50 uppercase tracking-wide">
                              <th className="text-left px-4 py-3">Data</th>
                              <th className="text-left px-4 py-3">Funcionário</th>
                              <th className="text-left px-4 py-3">Cargo</th>
                              <th className="text-left px-4 py-3">Obra</th>
                              <th className="text-left px-4 py-3">Obs</th>
                              <th className="px-4 py-3"></th>
                            </tr>
                          </thead>
                          <tbody>
                            {[...diarias].sort((a,b) => b.data.localeCompare(a.data)).map(d => {
                              const func = funcionarios.find(f => f.id === d.funcionarioId);
                              return (
                                <tr key={d.id} className="border-t border-gray-50 hover:bg-gray-50">
                                  <td className="px-4 py-3 text-gray-600 whitespace-nowrap">{new Date(d.data+"T00:00:00").toLocaleDateString("pt-BR")}</td>
                                  <td className="px-4 py-3 font-medium text-gray-700">{func ? func.nome : "—"}</td>
                                  <td className="px-4 py-3">
                                    {func && <span className={`px-2 py-0.5 rounded-full text-xs font-medium ${func.cargo === "Eletricista" ? "bg-blue-100 text-blue-700" : "bg-orange-100 text-orange-700"}`}>{func.cargo}</span>}
                                  </td>
                                  <td className="px-4 py-3 text-gray-500">{d.obra || "—"}</td>
                                  <td className="px-4 py-3 text-gray-400 text-xs">{d.obs || "—"}</td>
                                  <td className="px-4 py-3">
                                    <div style={{ display:"flex", gap:"8px", justifyContent:"flex-end" }}>
                                      <button onClick={() => { setFormDiaria({ ...d, funcionarioId: String(d.funcionarioId) }); setEditDiariaId(d.id); }} style={{ fontSize:"12px", color:"#60a5fa", cursor:"pointer", background:"none", border:"none" }}>✎</button>
                                      <button onClick={() => setDiarias(p => p.filter(x => x.id !== d.id))} style={{ fontSize:"12px", color:"#f87171", cursor:"pointer", background:"none", border:"none" }}>✕</button>
                                    </div>
                                  </td>
                                </tr>
                              );
                            })}
                            {diarias.length === 0 && (
                              <tr><td colSpan={6} className="px-4 py-8 text-center text-gray-400 text-sm">Nenhuma diária registrada ainda.</td></tr>
                            )}
                          </tbody>
                        </table>
                      </div>
                      <div className="px-5 py-5 border-t border-gray-100 bg-gray-50">
                        <p className="text-xs font-semibold text-gray-500 mb-3">{editDiariaId !== null ? "✎ Editando diária" : "Registrar Nova Diária"}</p>
                        <div className="grid grid-cols-2 md:grid-cols-4 gap-3">
                          <div>
                            <label className="text-xs text-gray-500 font-medium block mb-1">Data *</label>
                            <input type="date" value={formDiaria.data} onChange={e => setFD("data", e.target.value)}
                              className="border border-gray-200 rounded-lg px-3 py-2 text-sm w-full focus:outline-none focus:ring-2 focus:ring-green-400" />
                          </div>
                          <div>
                            <label className="text-xs text-gray-500 font-medium block mb-1">Funcionário *</label>
                            <select value={formDiaria.funcionarioId} onChange={e => setFD("funcionarioId", e.target.value)}
                              className="border border-gray-200 rounded-lg px-3 py-2 text-sm w-full focus:outline-none focus:ring-2 focus:ring-green-400">
                              <option value="">Selecione...</option>
                              {funcionarios.map(f => <option key={f.id} value={f.id}>{f.nome} ({f.cargo})</option>)}
                            </select>
                          </div>
                          <div>
                            <label className="text-xs text-gray-500 font-medium block mb-1">Obra</label>
                            <select value={formDiaria.obra} onChange={e => setFD("obra", e.target.value)}
                              className="border border-gray-200 rounded-lg px-3 py-2 text-sm w-full focus:outline-none focus:ring-2 focus:ring-green-400">
                              <option value="">— Selecione —</option>
                              {obras.map(o => <option key={o.id} value={o.obra}>{o.obra}</option>)}
                            </select>
                          </div>
                          <div>
                            <label className="text-xs text-gray-500 font-medium block mb-1">Observação</label>
                            <input type="text" value={formDiaria.obs} onChange={e => setFD("obs", e.target.value)} placeholder="Opcional..."
                              className="border border-gray-200 rounded-lg px-3 py-2 text-sm w-full focus:outline-none focus:ring-2 focus:ring-green-400" />
                          </div>
                        </div>
                        <div style={{ display:"flex", gap:"8px", marginTop:"16px" }}>
                          <button onClick={saveDiaria} style={{ backgroundColor:GREEN, color:"white", fontSize:"14px", padding:"8px 24px", borderRadius:"8px", border:"none", cursor:"pointer", fontWeight:500 }}>
                            {editDiariaId !== null ? "Salvar Edição" : "+ Registrar Diária"}
                          </button>
                          {editDiariaId !== null && (
                            <button onClick={() => { setFormDiaria(emptyFormDiaria); setEditDiariaId(null); }} style={{ fontSize:"14px", padding:"8px 24px", borderRadius:"8px", border:"1px solid #d1d5db", color:"#6b7280", background:"white", cursor:"pointer" }}>Cancelar</button>
                          )}
                        </div>
                      </div>
                    </div>
                  )}

                  {/* ── Funcionários ── */}
                  {subTab === "funcionarios" && (
                    <div>
                      <div className="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
                        <h3 className="font-semibold text-gray-700">Cadastro de Funcionários</h3>
                        <span className="text-xs text-gray-400">{funcionarios.length} funcionários</span>
                      </div>
                      <div className="overflow-x-auto">
                        <table className="w-full text-sm">
                          <thead>
                            <tr className="text-xs text-gray-400 bg-gray-50 uppercase tracking-wide">
                              <th className="text-left px-4 py-3">Nome</th>
                              <th className="text-left px-4 py-3">Cargo</th>
                              <th className="text-center px-4 py-3">Valor da Diária</th>
                              <th className="px-4 py-3"></th>
                            </tr>
                          </thead>
                          <tbody>
                            {funcionarios.map(f => (
                              <tr key={f.id} className="border-t border-gray-50 hover:bg-gray-50">
                                <td className="px-4 py-3 font-medium text-gray-700">{f.nome}</td>
                                <td className="px-4 py-3">
                                  <span className={`px-2 py-0.5 rounded-full text-xs font-medium ${f.cargo === "Eletricista" ? "bg-blue-100 text-blue-700" : "bg-orange-100 text-orange-700"}`}>{f.cargo}</span>
                                </td>
                                <td className="px-4 py-3 text-center font-semibold" style={{ color: GREEN }}>{f.valorDiaria.toLocaleString("pt-BR",{style:"currency",currency:"BRL"})}</td>
                                <td className="px-4 py-3">
                                  <div style={{ display:"flex", gap:"8px", justifyContent:"flex-end" }}>
                                    <button onClick={() => { setFormFunc({ nome:f.nome, cargo:f.cargo, valorDiaria:String(f.valorDiaria) }); setEditFuncId(f.id); }} style={{ fontSize:"12px", color:"#60a5fa", cursor:"pointer", background:"none", border:"none" }}>✎</button>
                                    <button onClick={() => setFuncionarios(p => p.filter(x => x.id !== f.id))} style={{ fontSize:"12px", color:"#f87171", cursor:"pointer", background:"none", border:"none" }}>✕</button>
                                  </div>
                                </td>
                              </tr>
                            ))}
                            {funcionarios.length === 0 && (
                              <tr><td colSpan={4} className="px-4 py-8 text-center text-gray-400 text-sm">Nenhum funcionário cadastrado.</td></tr>
                            )}
                          </tbody>
                        </table>
                      </div>
                      <div className="px-5 py-5 border-t border-gray-100 bg-gray-50">
                        <p className="text-xs font-semibold text-gray-500 mb-3">{editFuncId !== null ? "✎ Editando funcionário" : "Cadastrar Novo Funcionário"}</p>
                        <div className="grid grid-cols-2 md:grid-cols-3 gap-3">
                          <div>
                            <label className="text-xs text-gray-500 font-medium block mb-1">Nome *</label>
                            <input type="text" value={formFunc.nome} onChange={e => setFF("nome", e.target.value)} placeholder="Nome completo"
                              className="border border-gray-200 rounded-lg px-3 py-2 text-sm w-full focus:outline-none focus:ring-2 focus:ring-green-400" />
                          </div>
                          <div>
                            <label className="text-xs text-gray-500 font-medium block mb-1">Cargo *</label>
                            <select value={formFunc.cargo} onChange={e => setFF("cargo", e.target.value)}
                              className="border border-gray-200 rounded-lg px-3 py-2 text-sm w-full focus:outline-none focus:ring-2 focus:ring-green-400">
                              {CARGOS.map(c => <option key={c}>{c}</option>)}
                            </select>
                          </div>
                          <div>
                            <label className="text-xs text-gray-500 font-medium block mb-1">Valor da Diária (R$) *</label>
                            <input type="number" value={formFunc.valorDiaria} onChange={e => setFF("valorDiaria", e.target.value)} placeholder="Ex: 250"
                              className="border border-gray-200 rounded-lg px-3 py-2 text-sm w-full focus:outline-none focus:ring-2 focus:ring-green-400" />
                          </div>
                        </div>
                        <div style={{ display:"flex", gap:"8px", marginTop:"16px" }}>
                          <button onClick={saveFunc} style={{ backgroundColor:GREEN, color:"white", fontSize:"14px", padding:"8px 24px", borderRadius:"8px", border:"none", cursor:"pointer", fontWeight:500 }}>
                            {editFuncId !== null ? "Salvar Edição" : "+ Cadastrar Funcionário"}
                          </button>
                          {editFuncId !== null && (
                            <button onClick={() => { setFormFunc(emptyFormFunc); setEditFuncId(null); }} style={{ fontSize:"14px", padding:"8px 24px", borderRadius:"8px", border:"1px solid #d1d5db", color:"#6b7280", background:"white", cursor:"pointer" }}>Cancelar</button>
                          )}
                        </div>
                      </div>
                    </div>
                  )}

                </div>
              </div>
            )}

          </main>
        </div>
      );
    }

    ReactDOM.createRoot(document.getElementById("root")).render(<Dashboard />);
  </script>
</body>
</html>
